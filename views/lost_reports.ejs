<%- include('layout', {
  user,
  error,
  success,
  body: `
    <section class="page-header">
      <div>
        <h1>Lost Reports</h1>
        <p>Browse all reported lost items. Students can use this page to review existing lost reports and follow up with security if needed.</p>
      </div>
    </section>

    <section class="panel">
      <div class="panel-header">
        <form action="/student/lost-reports" method="get" class="search-form" style="margin-bottom:12px;">
          <input type="search" name="q" placeholder="Search lost reports..." value="${query || ''}" />
          <button type="submit">Search</button>
        </form>
      </div>
      ${reports && reports.length ? `
        <table>
          <thead>
            <tr><th>ID</th><th>Photo</th><th>Title</th><th>Description</th><th>Location</th><th>Reporter</th><th>Date</th><th>Status</th></tr>
          </thead>
          <tbody>
            ${reports.map(r => `
              <tr>
                <td>${r.id}</td>
                <td style="max-width:96px; padding:8px;">
                  ${r.image_url ? `<img src="${r.image_url}" alt="${r.title}" style="width:96px;height:64px;object-fit:cover;border-radius:8px;" />` : '<span style="color:#6b7280;">No image</span>'}
                </td>
                <td>${r.title}</td>
                <td>${r.description}</td>
                <td>${r.location}</td>
                <td>${r.reporter || 'Unknown'}</td>
                <td>${new Date(r.created_at).toLocaleDateString()}</td>
                <td><span class="status-badge status-${r.status.replace(/\s+/g, '-')}">${r.status}</span></td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      ` : '<p>No lost reports have been submitted yet.</p>'}
    </section>
  `
}) %>
